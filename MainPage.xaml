<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="theflashcards.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label
                Text="The Flash Cards!"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Button
                x:Name="NewCardBtn"
                Text="Crie um novo card" 
                SemanticProperties.Hint="Mudança de Pagina"
                Clicked="GoToNewCardPage"
                HorizontalOptions="Fill" 
                BackgroundColor="Beige"
                FontSize="Subtitle"
                MaximumWidthRequest="400"
                TextColor="Black"/>

            <Button
                x:Name="SearchCardsBtn"
                Text="Procure por um card" 
                SemanticProperties.Hint="Mudança de Pagina"
                Clicked="SearchCards"
                HorizontalOptions="Fill" 
                BackgroundColor="Beige"
                FontSize="Subtitle"
                MaximumWidthRequest="400"
                TextColor="Black"/>

            <Button
                x:Name="BuildTestBtn"
                Text="Monte um Mini Teste" 
                SemanticProperties.Hint="Mudança de Pagina"
                Clicked="BuildTest"
                HorizontalOptions="Fill" 
                BackgroundColor="Beige"
                FontSize="Subtitle"
                MaximumWidthRequest="400"
                TextColor="Black"/>

            <Button
                x:Name="LogoutBtn"
                Text="Sair" 
                SemanticProperties.Hint="Mudança de Pagina"
                Clicked="Logout"
                HorizontalOptions="Fill" 
                BackgroundColor="Beige"
                FontSize="Subtitle"
                MaximumWidthRequest="400"
                TextColor="Black" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
