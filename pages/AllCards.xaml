<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="theflashcards.pages.AllCards"
             Shell.NavBarIsVisible="False">


    <ScrollView>
        <VerticalStackLayout
            Padding="{StaticResource DefaultPadding}"
            Spacing="{StaticResource DefaultSpacing}"
            BackgroundColor="{StaticResource BlueLight}" >

            <Label 
                Text="Todos os Cards"
                VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"
                TextColor="{StaticResource WhiteIce}"/>
            
            <!--Add collecionView para criar a viewModel e o model(se necessario) para essa page;-->
            <!--Esse collectionView deve carregar os itens do json, usando IPageLifecycleAware, INotifyPropertyChanged e etc...-->

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>