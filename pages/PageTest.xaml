<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:converters="clr-namespace:theflashcards.Converters"
             x:Class="theflashcards.pages.PageTest"
             x:Name="PageTestPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BooleanToTextConverter x:Key="BooleanToTextConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Background>
        <LinearGradientBrush>
            <GradientStop Color="{StaticResource BlueLazuli}" Offset="0.0"/>
            <GradientStop Color="{StaticResource BlueDark}" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout 
            Padding="{StaticResource DefaultPadding}"
            Spacing="{StaticResource DefaultSpacing}">

            <Grid ColumnDefinitions="100,*"
                  MaximumWidthRequest="{StaticResource MaxDefaultWidth}"
                  ColumnSpacing="0">
                <Image Source="logo_theflashcards_sem_fundo.png" 
                       MaximumWidthRequest="100"
                       Grid.Column="0"/>

                <Label Text="Mini Teste!"
                       Style="{StaticResource Headline}" 
                       SemanticProperties.HeadingLevel="Level1" 
                       TextColor="{StaticResource Platinum}"
                       VerticalOptions="Center"
                       Grid.Column="1"/>
            </Grid>

            <CollectionView ItemsSource="{Binding CardsForTest}"
                            MaximumWidthRequest="{StaticResource MaxDefaultWidth}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="10" 
                                       Orientation="Vertical"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Background="{StaticResource Platinum}"
                               HasShadow="True"
                               BorderColor="Transparent" >
                            <VerticalStackLayout>
                                <Label 
                                    Text="{Binding Category}" 
                                    FontSize="10"
                                    TextColor="{StaticResource BlueMedium}"/>
                                <Label 
                                    Text="{Binding Quest}" 
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Padding="10"
                                    TextColor="{StaticResource BlueDark}"/>
                                <Label 
                                    Text="{Binding Resp}" 
                                    FontSize="16"
                                    HorizontalOptions="Center"
                                    Padding="10"   
                                    TextColor="{StaticResource BlueMedium}"
                                    IsVisible="{Binding IsAnswerVisible}"/>

                                <Button 
                                    Text="{Binding IsAnswerVisible, Converter={StaticResource BooleanToTextConverter}}" 
                                    SemanticProperties.Hint="Mostrar resposta"
                                    Command="{Binding BindingContext.ToggleAnswerVisibilityCommand, Source={x:Reference PageTestPage}}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource BlueDark}"
                                    FontSize="Subtitle"
                                    TextColor="{StaticResource Platinum}"/>

                                <Grid ColumnDefinitions="*,*"
                                      MaximumWidthRequest="{StaticResource MaxDefaultWidth}"
                                      ColumnSpacing="10"
                                      RowDefinitions="Auto,Auto"
                                      Margin="0, 10, 0, 0">

                                    <Label Text="Iai, acertou?"
                                           FontSize="16"
                                           TextColor="{StaticResource BlueMedium}"
                                           Grid.Column="0"
                                           Grid.Row="0"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" 
                                           Margin="0, 0, 0, -3"/>

                                    <StackLayout Orientation="Horizontal"
                                         Grid.Column="0"
                                         Grid.Row="1"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                                        <RadioButton Content="Acertei"
                                                     TextColor="{StaticResource BlueMedium}"
                                                     Value="True"
                                                     CheckedChanged="OnAnswerCheckedChanged">
                                        </RadioButton>

                                        <RadioButton Content="Errei"
                                                     TextColor="{StaticResource BlueMedium}"
                                                     Value="False"
                                                     CheckedChanged="OnAnswerCheckedChanged">
                                        </RadioButton>
                                    </StackLayout>

                                    <Label Text="O que achou desse card?"
                                           FontSize="16"
                                           TextColor="{StaticResource BlueMedium}"
                                           Grid.Column="1"
                                           Grid.Row="0"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" 
                                           Margin="0, 0, 0, -3"/>

                                    <StackLayout Orientation="Horizontal"
                                         Grid.Column="1"
                                         Grid.Row="1"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">
                                        <RadioButton Content="Fácil"
                                                     TextColor="{StaticResource BlueMedium}"
                                                     Value="Easy"
                                                     CheckedChanged="OnDifficultyCheckedChanged">
                                        </RadioButton>

                                        <RadioButton Content="Médio"
                                                     TextColor="{StaticResource BlueMedium}"
                                                     Value="Medium"
                                                     CheckedChanged="OnDifficultyCheckedChanged">
                                        </RadioButton>

                                        <RadioButton Content="Difícil"
                                                     TextColor="{StaticResource BlueMedium}"
                                                     Value="Hard"
                                                     CheckedChanged="OnDifficultyCheckedChanged">
                                        </RadioButton>
                                    </StackLayout>

                                </Grid>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button 
                Text="Finalizar simulado!" 
                FontSize="Subtitle"
                MaximumWidthRequest="{StaticResource MaxDefaultWidth}"
                BackgroundColor="{StaticResource BlueDark}"
                TextColor="{StaticResource Platinum}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
