<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="theflashcards.pages.EndTestPopup"
             x:Name="EndTestPopupPage"
             Color="{StaticResource BlueMedium}"
             HorizontalOptions="Center">
             
    <VerticalStackLayout 
        Padding="{StaticResource DefaultPadding}"
        Spacing="{StaticResource DefaultSpacing}"
        Background="{StaticResource BlueDark}">

    <Label
        Text="Simulado salvo!"
        Style="{StaticResource Headline}"
        SemanticProperties.HeadingLevel="Level1" 
        TextColor="{StaticResource Platinum}"
        VerticalOptions="Center"
        Margin="100, 50"
        />  
        
    </VerticalStackLayout>

</toolkit:Popup>